# =============================================
#   Smart Email Assistant — .gitignore
#   NEVER commit .env files — they contain secrets
# =============================================

# ----- Environment / Secrets -----
.env
.env.local
.env.*.local
*.env

# ----- Java / Maven (Backend) -----
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/wrapper/maven-wrapper.properties
*.class
*.jar
*.war
*.ear
*.log

# ----- Node / Vite (Frontend) -----
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# ----- IDE -----
.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/

# ----- OS -----
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
